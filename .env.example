# Feishu Bridge Configuration
# IMPORTANT: Create a NEW independent Feishu app for this bridge.
# Do NOT reuse cli_a92d11a974b89bcd (mi-feishu MCP app) — event routing will conflict.
# See: https://open.feishu.cn/app to create a new app with im:message permissions.
APP_ID=your_new_app_id_here
APP_SECRET=your_new_app_secret_here
LOG_LEVEL=INFO
WORKING_DIR=.

# Claude Code SDK settings
# CLAUDE_TIMEOUT: seconds to wait for Claude response (default: 3600)
CLAUDE_TIMEOUT=3600
# MAX_CONCURRENT_TASKS: max parallel Claude sessions (default: 5)
MAX_CONCURRENT_TASKS=5
# ALLOWED_TOOLS: comma-separated list of allowed Claude tools (default: all tools allowed)
# Example: ALLOWED_TOOLS=Read,Bash,Write
ALLOWED_TOOLS=
